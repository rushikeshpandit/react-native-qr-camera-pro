{
  "name": "react-native-qr-camera-pro",
  "version": "1.0.0",
  "description": "react-native-qr-camera-pro is a lightweight, high-performance React Native QR and barcode scanner built with native Swift and Kotlin using Fabric and TurboModules. It provides fast QR and barcode scanning, torch control, customizable overlay UI, and production-grade camera lifecycle handling with zero unnecessary dependencies. Designed for the New React Native Architecture with strict TypeScript support, clean APIs, and optimized native performance for both iOS and Android",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-qr-camera-pro-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "commitlint": "commitlint"
  },
  "keywords": [
    "react-native",
    "react-native-qr-scanner",
    "qr-scanner",
    "qr-code",
    "barcode-scanner",
    "react-native-camera",
    "qr-reader",
    "camera-x",
    "mlkit",
    "avfoundation",
    "react-native-fabric",
    "react-native-turbo-module",
    "react-native-new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rushikeshpandit/react-native-qr-camera-pro.git"
  },
  "author": "Rushikesh Pandit <rushikesh.d.pandit@gmail.com> (https://github.com/rushikeshpandit)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/rushikeshpandit/react-native-qr-camera-pro/issues"
  },
  "homepage": "https://github.com/rushikeshpandit/react-native-qr-camera-pro#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "commitlint": "^19.8.1",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "lefthook": "^2.0.3",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.13",
    "release-it": "^19.0.4",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "QrCameraProSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.qrcamerapro"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint"
    ],
    "version": "0.62.0"
  }
}
